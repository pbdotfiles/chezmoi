#!/bin/bash

{{ include ".chezmoitemplates/pause_on_error" }}

# Trigger if the crontab source file changes
# .crontab hash: {{ include "dot_crontab.tmpl" | sha256sum }}

echo "⏰ Updating system crontab from ~/.crontab..."

if [ -f "$HOME/.crontab" ]; then
    crontab "$HOME/.crontab"
    echo "✅ System crontab updated successfully."
else
    echo "❌ Error: ~/.crontab not found."
    exit 1
fi
