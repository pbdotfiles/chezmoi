#!/bin/bash

{{ include ".chezmoitemplates/pause_on_error" }}

set -euo pipefail

{{ include ".chezmoitemplates/tls_env" }}
{{- $is_suse := eq (include ".chezmoitemplates/is_suse" | trim) "true" -}}

# Skip sudo_keepalive on OpenSUSE — no root access on these hosts.
{{- if $is_suse }}
echo "[nvim setup] OpenSUSE/SLES detected; sudo_keepalive skipped"
{{- else }}
{{ include ".chezmoitemplates/sudo_keepalive" }}
sudo_keepalive
{{- end }}

echo "======================================================="
echo "  Setting up Neovim (Stable) + LazyVim + NVM  "
echo "======================================================="

# -----------------------------------------------------------------------------
# 1. INSTALL DEPENDENCIES
# -----------------------------------------------------------------------------

# Ensure 'fd' is linked correctly (Ubuntu installs it as fdfind)
mkdir -p "$HOME/.local/bin"
if command -v fdfind >/dev/null 2>&1 && ! command -v fd >/dev/null 2>&1; then
    echo "🔗 Symlinking fdfind to fd..."
    ln -sf "$(command -v fdfind)" "$HOME/.local/bin/fd"
fi

echo "FZF installation..."
# Remove apt-installed fzf if present (too old). `command -v dpkg` makes this a no-op on non-Debian.
if command -v dpkg >/dev/null 2>&1 && dpkg -l | grep -q "^ii.*fzf"; then
    echo "⚠️  Found apt-installed fzf. Removing it to ensure latest version..."
    sudo apt remove -y fzf
fi
# Install/Update FZF from Git.
if [ -d "$HOME/.fzf" ]; then
    if ( cd "$HOME/.fzf" && git rev-parse --git-dir >/dev/null 2>&1 ); then
        echo "🔄 Updating existing FZF..."
        ( cd "$HOME/.fzf" && git pull && ./install --all --no-bash --no-zsh --no-fish --no-nushell )
    else
        echo "⚠️  Existing ~/.fzf is not a valid git repo (previous run interrupted?). Re-cloning..."
        rm -rf "$HOME/.fzf"
        git clone --depth 1 https://github.com/junegunn/fzf.git "$HOME/.fzf"
        "$HOME/.fzf/install" --all --no-bash --no-zsh --no-fish --no-nushell
    fi
else
    echo "✨ Installing FZF (Fresh)..."
    git clone --depth 1 https://github.com/junegunn/fzf.git "$HOME/.fzf"
    "$HOME/.fzf/install" --all --no-bash --no-zsh --no-fish --no-nushell
fi

# Ensure the binary is symlinked to your user bin
ln -sf "$HOME/.fzf/bin/fzf" "$HOME/.local/bin/fzf"

echo "✅ FZF Setup Complete."

#-------------------------------------------------------------------------------- 
# 1.5 MAKE PYTHON VENV WITH PYNVIM
#-------------------------------------------------------------------------------- 
# We use a dedicated venv to avoid conflicts with system python or other projects
NVIM_VENV="$HOME/.local/share/nvim/venv"

if [ ! -d "$NVIM_VENV" ]; then
    echo "🐍 Creating Python virtual environment for Neovim..."
    python3 -m venv "$NVIM_VENV"
    
    echo "📦 Installing pynvim in dedicated venv..."
    "$NVIM_VENV/bin/pip" install --upgrade pip pynvim
else
    echo "✅ Neovim Python venv already exists."
    "$NVIM_VENV/bin/pip" install --upgrade pynvim
fi

# -----------------------------------------------------------------------------
# 2. INSTALL NVM & NODE.JS (LTS)
# -----------------------------------------------------------------------------
export NVM_DIR="$HOME/.nvm"

echo "🔍 Fetching latest NVM version..."
NVM_VERSION=$(curl -s https://api.github.com/repos/nvm-sh/nvm/releases/latest | jq -r '.tag_name')

if [ -z "$NVM_VERSION" ] || [ "$NVM_VERSION" == "null" ]; then
    echo "❌ Error: Could not fetch NVM version. Defaulting to v0.40.3"
    NVM_VERSION="v0.40.3"
fi

if [ ! -d "$NVM_DIR" ]; then
    echo "Installing NVM ($NVM_VERSION)..."
    git clone https://github.com/nvm-sh/nvm.git "$NVM_DIR"
    cd "$NVM_DIR"
    git checkout "$NVM_VERSION"
    cd - > /dev/null
else
    echo "✅ NVM already installed. Checking for updates."
    cd "$NVM_DIR"
    git fetch --tags
    git checkout "$NVM_VERSION"
    cd - > /dev/null
fi

set +u # disable strict variable checking for NVM

# Load NVM for this session
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

echo "🟢 Installing Node.js LTS..."
nvm install --lts
nvm use --lts
nvm alias default 'lts/*'

# Persist CA bundle for npm-driven nvim/mason/Copilot invocations.
if [ -n "${SYSTEM_CA_BUNDLE:-}" ]; then
    npm config set cafile "$SYSTEM_CA_BUNDLE"
    # also disable strict-ssl for compatibility with corporate TLS inspection
    npm config set strict-ssl false
fi

{{- $features := dig .chezmoi.hostname (dict) .hosts_features -}}
{{- if dig "runs_within_wsl" false $features }}
# Remove xclip and wl-clipboard to force using win32yank (to be installed manually at the moment)
sudo apt remove -y xclip wl-clipboard
{{- end }}

# Install core global tools for Neovim
echo "📦 Installing global npm packages for Neovim..."
npm install -g neovim tree-sitter-cli

set -u # re-enable strict variable checking

# -----------------------------------------------------------------------------
# 2.5 INSTALL LAZYGIT
# -----------------------------------------------------------------------------

# Define install location matching your other binaries
BIN_DIR="$HOME/bin"
mkdir -p "$BIN_DIR"

# Check if lazygit is installed
if command -v lazygit &> /dev/null; then
    echo "Lazygit is already installed."
    # Optional: You could add version checking logic here to force updates
    # For now, we'll assume if it exists, it's fine.
else
    echo "⬇️  Installing Lazygit (Latest)..."
    
    # Get the latest release version tag from GitHub API
    LAZYGIT_VERSION=$(curl -s "https://api.github.com/repos/jesseduffield/lazygit/releases/latest" | grep -Po '"tag_name": "v\K[^"]*')
    
    echo "Detected version: ${LAZYGIT_VERSION}"

    # Download the tarball
    curl -Lo lazygit.tar.gz "https://github.com/jesseduffield/lazygit/releases/latest/download/lazygit_${LAZYGIT_VERSION}_Linux_x86_64.tar.gz"

    # Extract just the binary
    tar xf lazygit.tar.gz lazygit

    # Use absolute path to avoid `./install` shims (e.g. fzf's).
    /usr/bin/install lazygit "$BIN_DIR"

    # Cleanup
    rm lazygit.tar.gz lazygit
    
    echo "✅ Lazygit installed to $BIN_DIR/lazygit"
fi
# -----------------------------------------------------------------------------
# 3. INSTALL NEOVIM (LATEST STABLE BINARY)
# -----------------------------------------------------------------------------

BIN_DIR="$HOME/bin"
mkdir -p "$BIN_DIR"

{{- if $is_suse }}
# OpenSUSE: older glibc cannot run the official tarball. Use conda-forge via pixi.
echo "📥 Installing Neovim via pixi (conda-forge)..."
if ! command -v pixi >/dev/null 2>&1; then
    echo "⚠️  pixi not yet installed. Run 'chezmoi apply' again after pixi is ready."
    exit 0
fi
pixi global install nvim
ln -sf "$HOME/.pixi/bin/nvim" "$BIN_DIR/nvim"
{{- else }}
# Ubuntu / WSL / others: official stable tarball from GitHub. Uses the binary
# tarball to avoid AppImage FUSE issues and startup lag.
NVIM_INSTALL_PATH="$HOME/.local/share/nvim-linux-x86_64"

echo "📥 Fetching Neovim Stable..."
# Removing old install to ensure clean update
rm -rf "$NVIM_INSTALL_PATH"
rm -rf "$HOME/.local/share/nvim-linux64"

# Download Stable Tarball
curl -LO https://github.com/neovim/neovim/releases/download/stable/nvim-linux-x86_64.tar.gz

# Extract
tar -xzf nvim-linux-x86_64.tar.gz -C "$HOME/.local/share/"
rm nvim-linux-x86_64.tar.gz

# Symlink to ~/bin (on PATH via ~/.bash_aliases)
ln -sf "$NVIM_INSTALL_PATH/bin/nvim" "$BIN_DIR/nvim"
{{- end }}

echo "✅ Neovim Stable installed to $BIN_DIR/nvim"
"$BIN_DIR/nvim" --version | head -n 1

# -----------------------------------------------------------------------------
# 4. CONFIGURATION MERGE (LAZYVIM + CHEZMOI)
# -----------------------------------------------------------------------------
# Strategy: Download LazyVim starter to temp, then copy ONLY MISSING files
# to ~/.config/nvim. This respects your Chezmoi dotfiles while ensuring
# the full LazyVim environment exists.

CONFIG_DIR="$HOME/.config/nvim"

echo "🎨 Bootstrapping LazyVim Config..."

# 1. Create a clean temp version of LazyVim starter
TEMP_DIR=$(mktemp -d)
git clone --depth 1 https://github.com/LazyVim/starter "$TEMP_DIR"
rm -rf "$TEMP_DIR/.git"

# 2. Ensure Config Dir exists
mkdir -p "$CONFIG_DIR"

# 3. Merge: Copy files from Starter -> Config, but DO NOT overwrite existing ones.
#    This preserves your Chezmoi files (lua/config/keymaps.lua, etc)
#    while filling in the rest of the LazyVim structure.
echo "🔄 Merging LazyVim starter with your dotfiles..."
cp -rn "$TEMP_DIR/." "$CONFIG_DIR/" || true

# Cleanup
rm -rf "$TEMP_DIR"

echo "✅ Configuration merged."
echo "   - Your dotfiles: PRESERVED"
echo "   - Missing LazyVim files: ADDED"

# -----------------------------------------------------------------------------
# 5. FINALIZATION
# -----------------------------------------------------------------------------
# Ensure PATH is correct for current session
export PATH="$BIN_DIR:$PATH"

echo "🎉 Setup Complete! Restart your shell."
echo "   Run 'nvim' to finish plugin installation."

# -----------------------------------------------------------------------------
# 6. POST-INSTALL FIXES
# -----------------------------------------------------------------------------

# Install every plugin in headless mode
"$BIN_DIR/nvim" --headless "+Lazy! sync" +qa

# Delete all tree-sitter-cli files, such that lazy is forced to reinstall tree-sitter-cli
# Fixes a bug where tree-sitter-cli is compiled for an old version of neovim, then we update
# neovim and the old tree-sitter-cli becomes incompatible with the new neovim.
rm -rf "$HOME/.local/share/nvim/tree-sitter"

# -----------------------------------------------------------------------------
# 7. INSTALL ZOXIDE
# -----------------------------------------------------------------------------
echo "🚀 Fetching latest Zoxide..."

# 1. Get the latest release tag
ZOX_TAG=$(curl -s "https://api.github.com/repos/ajeetdsouza/zoxide/releases/latest" | jq -r '.tag_name')
ZOX_VER="${ZOX_TAG#v}"

# 2. Download and Extract directly to binary folder
# Using the musl version for maximum compatibility across all your machines
TEMP_DIR=$(mktemp -d)
curl -L "https://github.com/ajeetdsouza/zoxide/releases/download/${ZOX_TAG}/zoxide-${ZOX_VER}-x86_64-unknown-linux-musl.tar.gz" -o "$TEMP_DIR/zoxide.tar.gz"

tar -xzf "$TEMP_DIR/zoxide.tar.gz" -C "$TEMP_DIR" zoxide
mkdir -p "$HOME/.local/bin"
install "$TEMP_DIR/zoxide" "$HOME/.local/bin/zoxide"

rm -rf "$TEMP_DIR"
echo "✅ Zoxide $ZOX_TAG installed to $HOME/.local/bin/zoxide"

# -----------------------------------------------------------------------------
# 8. INSTALL YAZI
# -----------------------------------------------------------------------------

echo "🚀 Fetching latest Yazi..."

# 1. Get latest release tag
YAZI_TAG=$(curl -s "https://api.github.com/repos/sxyazi/yazi/releases/latest" | jq -r '.tag_name')

# 2. Download and Extract
TEMP_DIR=$(mktemp -d)
curl -L "https://github.com/sxyazi/yazi/releases/download/${YAZI_TAG}/yazi-x86_64-unknown-linux-musl.zip" -o "$TEMP_DIR/yazi.zip"

unzip -q "$TEMP_DIR/yazi.zip" -d "$TEMP_DIR"

# 3. Install binaries (yazi and ya)
# The zip extracts into a folder named yazi-x86_64-unknown-linux-musl/
mkdir -p "$HOME/.local/bin"
install -m 755 "$TEMP_DIR/yazi-x86_64-unknown-linux-musl/yazi" "$HOME/.local/bin/yazi"
install -m 755 "$TEMP_DIR/yazi-x86_64-unknown-linux-musl/ya" "$HOME/.local/bin/ya"

rm -rf "$TEMP_DIR"
echo "✅ Yazi $YAZI_TAG installed to $HOME/.local/bin/yazi"
